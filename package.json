{
  "name": "@pokujs/one-double-zero",
  "private": false,
  "version": "1.0.0",
  "description": "☔️ A Poku plugin for V8 code coverage using One Double Zero.",
  "main": "./lib/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pokujs/one-double-zero.git"
  },
  "homepage": "https://poku.io",
  "bugs": {
    "url": "https://github.com/pokujs/one-double-zero/issues"
  },
  "author": "https://github.com/wellwelwel",
  "funding": {
    "type": "github",
    "url": "https://github.com/pokujs/one-double-zero?sponsor=1"
  },
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=20.x.x"
  },
  "scripts": {
    "pretest": "npm run build",
    "test": "poku test/e2e",
    "prebuild": "rm -rf lib",
    "build": "tsc",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .github/workflows/*.yml .",
    "update": "pu minor && npm i && (npm audit fix || true)",
    "postupdate": "npm run lint:fix"
  },
  "dependencies": {
    "@bcoe/v8-coverage": "^1.0.2",
    "glob": "^13.0.6",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsonc.min": "^1.1.2",
    "one-double-zero": "^1.1.1",
    "toml.min": "^0.1.3",
    "yaml.min": "^1.0.0"
  },
  "peerDependencies": {
    "poku": "^4.1.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/node": "^25.5.0",
    "packages-update": "^2.0.0",
    "poku": "^4.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "🐷",
    "poku",
    "pokujs",
    "testing",
    "plugin",
    "coverage",
    "v8",
    "istanbul",
    "one-double-zero",
    "yaml",
    "toml",
    "jsonc"
  ]
}
